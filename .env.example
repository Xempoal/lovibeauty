# Copy to `.env` and fill in. The .env file is gitignored.
#
# Find these values in: Supabase Dashboard → Project Settings → API.
#
# Production deploy (Cloudflare Pages): set the same vars via dashboard or
#   wrangler pages secret put SUPABASE_URL
#   wrangler pages secret put SUPABASE_ANON_KEY
#   wrangler pages secret put SUPABASE_SERVICE_ROLE_KEY  # Functions only — never exposed to the browser

# Public — safe to embed in the browser bundle (RLS guards the catalog).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only — bypasses RLS. Use exclusively from Cloudflare Functions.
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel — 6-digit PIN for the studio owner's login.
# Server-only: validated inside functions/api/admin/login. In prod:
#   wrangler pages secret put ADMIN_PIN
ADMIN_PIN=123456

# Staff PIN — same panel, role "staff": everything except Configuración
# (CLABE, WhatsApp, PIN change). Optional; defaults to 000000 when unset.
#   wrangler pages secret put STAFF_PIN
STAFF_PIN=000000

# ─────────────────────────────────────────────────────────────────────────────
# Pagos con tarjeta (OPCIONAL) — todo el código ya está listo.
# Mientras estas variables estén vacías, el sitio cobra solo por transferencia.
# Para activar el cobro con tarjeta basta llenar las del proveedor elegido y
# apuntar su webhook a  https://TU_DOMINIO/api/payments/webhook
# (en prod, setear cada una con `wrangler pages secret put NOMBRE`).
# ─────────────────────────────────────────────────────────────────────────────

# Proveedor activo: stripe | mercadopago | paypal   (vacío = pagos desactivados)
PAYMENT_PROVIDER=
# Moneda ISO (MXN, USD, …)
PAYMENT_CURRENCY=MXN
# Qué se cobra con tarjeta: deposit (anticipo) | full (total del servicio)
PAYMENT_CHARGE=deposit
# URL pública del sitio, sin slash final (para redirigir de regreso del pago)
PUBLIC_SITE_URL=

# Stripe (Dashboard → Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mercado Pago (Tus integraciones → Credenciales)
MERCADOPAGO_ACCESS_TOKEN=

# PayPal (Developer Dashboard → Apps & Credentials). PAYPAL_ENV: sandbox | live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
